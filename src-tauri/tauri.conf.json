{
  "productName": "FlowVid",
  "version": "1.0.1",
  "identifier": "com.flowvid.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FlowVid",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https: data:; media-src 'self' https: http:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https: http://localhost:* http://*; frame-src https://www.youtube-nocookie.com https://www.youtube.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "lib/**/*"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc2ODY2QzE0Qjk4OUVGOTcKUldTWDc0bTVGR3lHZG8xYktMcHA3VFlBSGlFdGg2N3lXMm4zclBpckkrRk1pYWQxMWRsVmttQVYK",
      "endpoints": [
        "https://github.com/FxPandaa/FlowVidPC/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  }
}
